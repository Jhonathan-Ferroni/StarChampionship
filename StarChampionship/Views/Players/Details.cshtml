@model StarChampionship.Models.Player

@{
    ViewData["Title"] = "Detalhes do Jogador";
}

<div class="container">
    <h2 class="mb-4 text-primary"><i class="fas fa-search"></i> @ViewData["Title"]</h2>

    <div class="card shadow-lg border-0">
        <div class="card-header bg-dark text-white">
            <h4 class="mb-0">@Model.Name</h4>
        </div>
        <div class="card-body">
            <div class="row align-items-center">
                <div class="col-md-4 text-center border-end">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="Foto de @Model.Name" class="img-thumbnail shadow-sm mb-3" style="width: 200px; height: 200px; object-fit: cover; border-radius: 50%; border: 4px solid #0d6efd;" />
                    }
                    else
                    {
                        <div class="bg-secondary text-white d-flex align-items-center justify-content-center mx-auto shadow-sm mb-3" style="width: 200px; height: 200px; border-radius: 50%;">
                            <i class="fas fa-user fa-5x"></i>
                        </div>
                    }
                    <div class="overall-badge p-2">
                        <h5 class="text-muted">OVERALL</h5>
                        <span class="badge rounded-pill bg-success" style="font-size: 2.5rem;">@Model.Overall.ToString("F0")</span>
                    </div>
                </div>

                <div class="col-md-8">
                    <h5 class="text-primary border-bottom pb-2">Status Técnicos</h5>

                    <div class="row mt-3 text-center">
                        <div class="col-6 col-sm-3 mb-4">
                            <div class="p-2 border rounded bg-light">
                                <small class="text-muted d-block text-uppercase">Chute</small>
                                <strong class="h4">@Model.Shoot</strong>
                            </div>
                        </div>
                        <div class="col-6 col-sm-3 mb-4">
                            <div class="p-2 border rounded bg-light">
                                <small class="text-muted d-block text-uppercase">Drible</small>
                                <strong class="h4">@Model.Dribble</strong>
                            </div>
                        </div>
                        <div class="col-6 col-sm-3 mb-4">
                            <div class="p-2 border rounded bg-light">
                                <small class="text-muted d-block text-uppercase">Domínio</small>
                                <strong class="h4">@Model.FirstTouch</strong>
                            </div>
                        </div>
                        <div class="col-6 col-sm-3 mb-4">
                            <div class="p-2 border rounded bg-light">
                                <small class="text-muted d-block text-uppercase">Controle</small>
                                <strong class="h4">@Model.BallControl</strong>
                            </div>
                        </div>
                        <div class="col-6 col-sm-3 mb-4">
                            <div class="p-2 border rounded bg-light">
                                <small class="text-muted d-block text-uppercase">Defesa</small>
                                <strong class="h4">@Model.Defense</strong>
                            </div>
                        </div>
                        <div class="col-6 col-sm-3 mb-4">
                            <div class="p-2 border rounded bg-light">
                                <small class="text-muted d-block text-uppercase">Passe</small>
                                <strong class="h4">@Model.Pass</strong>
                            </div>
                        </div>
                        <div class="col-6 col-sm-3 mb-4">
                            <div class="p-2 border rounded bg-light">
                                <small class="text-muted d-block text-uppercase">Veloc.</small>
                                <strong class="h4">@Model.Speed</strong>
                            </div>
                        </div>
                        <div class="col-6 col-sm-3 mb-4">
                            <div class="p-2 border rounded bg-light">
                                <small class="text-muted d-block text-uppercase">Força</small>
                                <strong class="h4">@Model.Strength</strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-footer bg-white text-end">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning"><i class="fas fa-edit"></i> Editar</a>
            <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Voltar</a>
        </div>
    </div>
</div>