@model StarChampionship.Models.Player

@{
    ViewData["Title"] = "Ficha do Atleta";
}

<style>
    /* Estilo da Carta FIFA */
    .fifa-card {
        width: 320px;
        height: 500px;
        background: linear-gradient(135deg, #e5c365 0%, #b88a1a 100%); /* Cor Ouro */
        border-radius: 15px;
        position: relative;
        padding: 20px;
        color: #1a1a1a;
        font-family: 'DIN Condesned', 'Arial Narrow', sans-serif;
        box-shadow: 0 15px 35px rgba(0,0,0,0.5);
        margin: 20px auto;
        border: 4px solid #f1d58f;
        clip-path: polygon(0% 15%, 15% 0%, 85% 0%, 100% 15%, 100% 85%, 85% 100%, 15% 100%, 0% 85%);
    }

    .card-top {
        display: flex;
        align-items: flex-start;
        margin-top: 25px;
    }

    .overall-info {
        text-align: center;
        line-height: 0.9;
        margin-right: 10px;
    }

    .overall-value {
        font-size: 3.5rem;
        font-weight: bold;
        display: block;
    }

    .player-photo {
        width: 180px;
        height: 180px;
        object-fit: cover;
        margin-left: auto;
        mask-image: linear-gradient(to bottom, black 80%, transparent 100%);
    }

    .player-name {
        text-align: center;
        font-size: 1.8rem;
        font-weight: bold;
        text-transform: uppercase;
        border-bottom: 2px solid rgba(0,0,0,0.1);
        margin: 10px 0;
        letter-spacing: 1px;
    }

    .stats-container {
        display: flex;
        justify-content: center;
        gap: 20px;
        padding-top: 10px;
    }

    .stat-col {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .stat-item {
        font-size: 1.2rem;
        text-transform: uppercase;
        margin-bottom: 5px;
    }

    .stat-value {
        font-weight: bold;
        margin-right: 5px;
    }

    .stat-label {
        color: #333;
        font-weight: 500;
    }

    .btn-container {
        margin-top: 30px;
        display: flex;
        justify-content: center;
        gap: 10px;
    }
</style>

<div class="container text-center">
    <div class="fifa-card shadow">
        <div class="card-top">
            <div class="overall-info">
                <span class="overall-value">@Model.Overall.ToString("F0")</span>
                <span style="font-size: 1.2rem; font-weight: bold;">JOG</span>
            </div>

            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" class="player-photo" alt="@Model.Name" />
            }
            else
            {
                <div class="player-photo d-flex align-items-center justify-content-center">
                    <i class="fas fa-user fa-7x text-dark-50"></i>
                </div>
            }
        </div>

        <div class="player-name">
            @Model.Name
        </div>

        <div class="stats-container">
            <div style="width: 3px; background: rgba(0,0,0,0.1); height: 120px;"></div>
            <ul class="stat-col">
                <li class="stat-item"><span class="stat-value">@Model.Shoot</span><span class="stat-label">CHU</span></li>
                <li class="stat-item"><span class="stat-value">@Model.Pass</span><span class="stat-label">PAS</span></li>
                <li class="stat-item"><span class="stat-value">@Model.Dribble</span><span class="stat-label">DRI</span></li>
                <li class="stat-item"><span class="stat-value">@Model.BallControl</span><span class="stat-label">CON</span></li>
            </ul>
            <div style="width: 3px; background: rgba(0,0,0,0.1); height: 120px;"></div>
            <ul class="stat-col">
                <li class="stat-item"><span class="stat-value">@Model.Defense</span><span class="stat-label">DEF</span></li>
                <li class="stat-item"><span class="stat-value">@Model.Speed</span><span class="stat-label">VEL</span></li>
                <li class="stat-item"><span class="stat-value">@Model.Strength</span><span class="stat-label">FOR</span></li>
                <li class="stat-item"><span class="stat-value">@Model.FirstTouch</span><span class="stat-label">DOM</span></li>
            </ul>
            <div style="width: 3px; background: rgba(0,0,0,0.1); height: 120px;"></div>
        </div>

    </div>

    <div class="btn-container">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-lg px-5 shadow">
            <i class="fas fa-edit"></i> EDITAR
        </a>
        <a asp-action="Index" class="btn btn-secondary btn-lg px-5 shadow">
            <i class="fas fa-undo"></i> VOLTAR
        </a>
    </div>
</div>