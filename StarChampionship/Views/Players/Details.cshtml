@model StarChampionship.Models.Player

@{
    ViewData["Title"] = "Ficha do Atleta";
}

<style>
    .card-wrapper {
        perspective: 1000px;
        padding: 20px 0;
    }

    .fifa-card {
        width: 320px;
        height: 550px;
        background: linear-gradient(135deg, #fbf2d5 0%, #e5c365 25%, #b88a1a 50%, #946d0a 100%);
        background-size: cover;
        border-radius: 10px;
        position: relative;
        padding: 20px;
        color: #1a1a1a;
        font-family: 'Oswald', sans-serif;
        box-shadow: 0 20px 40px rgba(0,0,0,0.6);
        margin: 0 auto;
        border: 2px solid #f1d58f;
        clip-path: polygon(0% 12%, 12% 0%, 88% 0%, 100% 12%, 100% 88%, 88% 100%, 12% 100%, 0% 88%);
        transition: transform 0.3s ease;
        overflow: hidden; /* Garante que nada saia da borda da carta */
    }

        .fifa-card:hover {
            transform: scale(1.02) rotateY(5deg);
        }

    @@media (max-width: 400px) {
        .fifa-card {
            transform: scale(0.85);
            margin-top: -40px;
            margin-bottom: -40px;
        }
    }

    /* MOLDURA DA FOTO */
    .photo-frame {
        width: 155px;
        height: 155px;
        background: radial-gradient(circle, #fbf2d5, #b88a1a);
        border: 4px solid #f1d58f;
        border-radius: 50%;
        position: absolute;
        right: 20px;
        top: 35px;
        overflow: hidden;
        box-shadow: 0 10px 20px rgba(0,0,0,0.3);
        z-index: 2;
    }

    .player-photo {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .card-top {
        display: flex;
        align-items: flex-start;
        margin-top: 40px;
        position: relative;
        z-index: 3;
    }

    .overall-info {
        text-align: center;
        line-height: 0.8;
        margin-left: 10px;
    }

    .overall-value {
        font-size: 4rem;
        font-weight: 800;
        display: block;
        letter-spacing: -2px;
    }

    /* NOME DO JOGADOR */
    .player-name {
        text-align: center;
        font-size: 1.8rem;
        font-weight: 800;
        text-transform: uppercase;
        background: rgba(0,0,0,0.05);
        margin: 165px 5px 15px 5px; /* Ajustado para dar espaço aos atributos abaixo */
        padding: 5px 0;
        border-top: 2px solid rgba(0,0,0,0.1);
        border-bottom: 2px solid rgba(0,0,0,0.1);
        position: relative;
        z-index: 3;
    }

    /* ATRIBUTOS */
    .stats-container {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 0 15px;
        position: relative;
        z-index: 3;
    }

    .stat-list {
        list-style: none;
        padding: 0;
        margin: 0;
        flex: 1;
    }

    .stat-item {
        font-size: 1.25rem; /* Reduzido levemente para evitar cortes */
        text-transform: uppercase;
        display: flex;
        justify-content: center;
        gap: 8px;
        margin-bottom: 3px;
    }

    .stat-value {
        font-weight: 800;
    }

    .stat-label {
        color: rgba(0,0,0,0.6);
        font-weight: 600;
    }

    .card-divider {
        background: rgba(0,0,0,0.15);
        height: 100px;
        width: 2px;
        margin: 0 10px;
    }

    .fifa-card::after {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(105deg, transparent 30%, rgba(255,255,255,0.15) 45%, rgba(255,255,255,0.05) 50%, transparent 54%);
        z-index: 1;
        pointer-events: none;
    }
</style>

<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;700;800&display=swap" rel="stylesheet">

<div class="container text-center">
    <div class="card-wrapper">
        <div class="fifa-card">
            @* MOLDURA COM FOTO *@
            <div class="photo-frame">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" class="player-photo" alt="@Model.Name" />
                }
                else
                {
                    <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-secondary">
                        <i class="bi bi-person-fill text-white" style="font-size: 5rem;"></i>
                    </div>
                }
            </div>

            <div class="card-top">
                <div class="overall-info text-dark">
                    <span class="overall-value">@Model.Overall.ToString("F0")</span>
                    <i class="bi bi-star-fill mt-1 d-block" style="font-size: 1.2rem;"></i>
                </div>
            </div>

            <div class="player-name text-dark">
                @Model.Name
            </div>

            @* Atributos em ordem idêntica ao Edit *@
            <div class="stats-container text-dark">
                <ul class="stat-list">
                    <li class="stat-item"><span class="stat-value">@Model.Shoot</span><span class="stat-label">CHU</span></li>
                    <li class="stat-item"><span class="stat-value">@Model.Dribble</span><span class="stat-label">DRI</span></li>
                    <li class="stat-item"><span class="stat-value">@Model.FirstTouch</span><span class="stat-label">DOM</span></li>
                    <li class="stat-item"><span class="stat-value">@Model.BallControl</span><span class="stat-label">CON</span></li>
                </ul>

                <div class="card-divider"></div>

                <ul class="stat-list">
                    <li class="stat-item"><span class="stat-value">@Model.Defense</span><span class="stat-label">DEF</span></li>
                    <li class="stat-item"><span class="stat-value">@Model.Pass</span><span class="stat-label">PAS</span></li>
                    <li class="stat-item"><span class="stat-value">@Model.Speed</span><span class="stat-label">VEL</span></li>
                    <li class="stat-item"><span class="stat-value">@Model.Strength</span><span class="stat-label">FOR</span></li>
                </ul>
            </div>
        </div>
    </div>

    @* Botões de Ação *@
    <div class="row justify-content-center mt-4 pb-5">
        <div class="col-12 col-md-auto mb-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-lg px-5 shadow fw-bold w-100">
                <i class="bi bi-pencil-square"></i> EDITAR
            </a>
        </div>
        <div class="col-12 col-md-auto mb-2">
            <a asp-action="Index" class="btn btn-secondary btn-lg px-5 shadow w-100">
                <i class="bi bi-arrow-left"></i> VOLTAR
            </a>
        </div>
    </div>
</div>