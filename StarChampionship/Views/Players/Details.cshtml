@model StarChampionship.Models.Player

@{
    ViewData["Title"] = "Ficha do Atleta";
}

<style>
    /* Container para permitir que a carta escale no mobile */
    .card-wrapper {
        perspective: 1000px;
        padding: 20px 0;
    }

    /* Estilo Pro da Carta FIFA */
    .fifa-card {
        width: 320px;
        height: 485px;
        background: url('https://selarondesign.com/wp-content/uploads/2021/08/FIFA-22-Ultimate-Team-Gold-Card-Template.png'); /* Fallback ou textura */
        background: linear-gradient(135deg, #fbf2d5 0%, #e5c365 25%, #b88a1a 50%, #946d0a 100%);
        background-size: cover;
        border-radius: 10px;
        position: relative;
        padding: 20px;
        color: #1a1a1a;
        font-family: 'Oswald', sans-serif; /* Fonte mais parecida com a do jogo */
        box-shadow: 0 20px 40px rgba(0,0,0,0.6);
        margin: 0 auto;
        border: 2px solid #f1d58f;
        clip-path: polygon(0% 12%, 12% 0%, 88% 0%, 100% 12%, 100% 88%, 88% 100%, 12% 100%, 0% 88%);
        transition: transform 0.3s ease;
    }

        .fifa-card:hover {
            transform: scale(1.02) rotateY(5deg);
        }

    /* Ajuste de escala para Celulares Pequenos */
    @@media (max-width: 380px) {
        .fifa-card {
            transform: scale(0.85);
            margin-top: -30px;
            margin-bottom: -30px;
        }
    }

    .card-top {
        display: flex;
        align-items: flex-start;
        margin-top: 35px;
        position: relative;
        z-index: 2;
    }

    .overall-info {
        text-align: center;
        line-height: 0.8;
        margin-left: 15px;
        border-right: 1.5px solid rgba(0,0,0,0.2);
        padding-right: 10px;
    }

    .overall-value {
        font-size: 4rem;
        font-weight: 800;
        display: block;
        letter-spacing: -2px;
    }

    .player-pos {
        font-size: 1.4rem;
        font-weight: 700;
        text-transform: uppercase;
        display: block;
        margin-top: 5px;
    }

    .player-photo {
        width: 190px;
        height: 190px;
        object-fit: cover;
        position: absolute;
        right: -10px;
        top: -10px;
        mask-image: linear-gradient(to bottom, black 85%, transparent 100%);
        -webkit-mask-image: linear-gradient(to bottom, black 85%, transparent 100%);
        filter: drop-shadow(5px 5px 10px rgba(0,0,0,0.3));
    }

    .player-name {
        text-align: center;
        font-size: 1.8rem;
        font-weight: 800;
        text-transform: uppercase;
        border-bottom: 2px solid rgba(0,0,0,0.15);
        margin: 15px 15px 10px 15px;
        padding-bottom: 5px;
        letter-spacing: 0px;
        position: relative;
        z-index: 3;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: 1fr 2px 1fr;
        align-items: center;
        padding: 0 25px;
        position: relative;
        z-index: 3;
    }

    .stat-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .stat-item {
        font-size: 1.25rem;
        text-transform: uppercase;
        display: flex;
        justify-content: space-between;
        margin-bottom: 2px;
    }

    .stat-value {
        font-weight: 800;
        margin-right: 8px;
    }

    .stat-label {
        color: rgba(0,0,0,0.7);
        font-weight: 500;
    }

    .card-divider {
        background: rgba(0,0,0,0.15);
        height: 100px;
        width: 2px;
    }

    /* Brilho reflexivo na carta */
    .fifa-card::after {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(105deg, transparent 30%, rgba(255,255,255,0.2) 45%, rgba(255,255,255,0.1) 50%, transparent 54%);
        z-index: 1;
        pointer-events: none;
    }
</style>

@* Importando a fonte Oswald do Google para ficar mais "FIFA" *@
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;700;800&display=swap" rel="stylesheet">

<div class="container text-center">
    <div class="card-wrapper">
        <div class="fifa-card">
            <div class="card-top">
                <div class="overall-info">
                    <span class="overall-value">@Model.Overall.ToString("F0")</span>
                    <span class="player-pos text-dark">JOG</span>
                    @* Opcional: Logo do seu time ou brasão do Star Championship *@
                    <i class="bi bi-star-fill text-dark mt-2 d-block"></i>
                </div>

                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" class="player-photo" alt="@Model.Name" />
                }
                else
                {
                    <div class="player-photo d-flex align-items-center justify-content-center">
                        <i class="bi bi-person-bounding-box" style="font-size: 6rem; opacity: 0.2;"></i>
                    </div>
                }
            </div>

            <div class="player-name">
                @Model.Name
            </div>

            <div class="stats-grid">
                <ul class="stat-list">
                    <li class="stat-item"><span class="stat-value">@Model.Shoot</span><span class="stat-label">CHU</span></li>
                    <li class="stat-item"><span class="stat-value">@Model.Pass</span><span class="stat-label">PAS</span></li>
                    <li class="stat-item"><span class="stat-value">@Model.Dribble</span><span class="stat-label">DRI</span></li>
                    <li class="stat-item"><span class="stat-value">@Model.BallControl</span><span class="stat-label">CON</span></li>
                </ul>

                <div class="card-divider"></div>

                <ul class="stat-list ms-3">
                    <li class="stat-item"><span class="stat-value">@Model.Defense</span><span class="stat-label">DEF</span></li>
                    <li class="stat-item"><span class="stat-value">@Model.Speed</span><span class="stat-label">VEL</span></li>
                    <li class="stat-item"><span class="stat-value">@Model.Strength</span><span class="stat-label">FOR</span></li>
                    <li class="stat-item"><span class="stat-value">@Model.FirstTouch</span><span class="stat-label">DOM</span></li>
                </ul>
            </div>
        </div>
    </div>

    @* Botões Responsivos *@
    <div class="row justify-content-center mt-4 pb-5">
        <div class="col-12 col-md-auto mb-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-lg px-5 shadow fw-bold w-100">
                <i class="bi bi-pencil-square"></i> EDITAR
            </a>
        </div>
        <div class="col-12 col-md-auto mb-2">
            <a asp-action="Index" class="btn btn-secondary btn-lg px-5 shadow w-100">
                <i class="bi bi-arrow-left"></i> VOLTAR
            </a>
        </div>
    </div>
</div>