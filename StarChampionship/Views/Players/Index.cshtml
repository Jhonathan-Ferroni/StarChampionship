@model IEnumerable<StarChampionship.Models.Player>

@{
    ViewData["Title"] = "Ranking de Jogadores";
    // Ordenação garantindo que o melhor apareça primeiro
    var jogadoresOrdenados = Model.OrderByDescending(p => p.Overall).ToList();
}

@* Cabeçalho Responsivo *@
<div class="row align-items-center mb-4 g-3">
    <div class="col-7 col-md-8">
        <h2 class="text-warning mb-0">
            <i class="bi bi-trophy-fill"></i> <span class="d-none d-sm-inline">@ViewData["Title"]</span><span class="d-inline d-sm-none">Jogadores</span>
        </h2>
    </div>
    <div class="col-5 col-md-4 text-end">
        <a asp-action="Create" class="btn btn-warning shadow fw-bold btn-sm btn-md-grow">
            <i class="bi bi-plus-circle"></i> <span class="d-none d-md-inline">Novo Craque</span><span class="d-inline d-md-none">Adicionar</span>
        </a>
    </div>
</div>

<div class="card bg-dark shadow border-secondary">
    @* --- VISÃO DESKTOP: TABELA (Oculta no Mobile) --- *@
    <div class="table-responsive d-none d-md-block">
        <table class="table table-dark table-hover align-middle mb-0">
            <thead>
                <tr class="bg-primary bg-gradient text-white">
                    <th style="width: 60px;" class="text-center border-0 small">#</th>
                    <th style="width: 80px;" class="text-center border-0 small">FOTO</th>
                    <th class="border-0 small">NOME</th>
                    <th class="text-center border-0 small">OVERALL</th>
                    <th class="border-0 small">TOP CARACTERÍSTICAS</th>
                    <th class="text-center border-0 small" style="min-width: 200px;">OPÇÕES</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int posicaoD = 1;
                }
                @foreach (var item in jogadoresOrdenados)
                {
                    var topStats = new Dictionary<string, double> {
                                { "CHU", item.Shoot }, { "DRI", item.Dribble }, { "DOM", item.FirstTouch },
                                { "CON", item.BallControl }, { "DEF", item.Defense }, { "PAS", item.Pass },
                                { "VEL", item.Speed }, { "FOR", item.Strength }
                                }.OrderByDescending(s => s.Value).Take(3);

                    <tr class="border-secondary">
                        <td class="text-center text-muted fw-bold">@(posicaoD++)º</td>
                        <td class="text-center">
                            <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://cdn-icons-png.flaticon.com/512/166/166344.png" : item.ImageUrl)"
                                 class="rounded-circle border border-warning" style="width: 45px; height: 45px; object-fit: cover;" />
                        </td>
                        <td><span class="fw-bold text-white">@item.Name</span></td>
                        <td class="text-center">
                            <span class="badge rounded-pill @(item.Overall >= 85 ? "bg-warning text-dark" : item.Overall >= 75 ? "bg-success" : "bg-info text-dark")" style="width: 40px;">
                                @item.Overall.ToString("F0")
                            </span>
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                @foreach (var stat in topStats)
                                {
                                    <small class="badge border border-secondary fw-normal" style="font-size: 0.7rem;">@stat.Key: <strong>@stat.Value</strong></small>
                                }
                            </div>
                        </td>
                        <td class="text-center">
                            <div class="btn-group btn-group-sm shadow-sm">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning"><i class="bi bi-pencil"></i></a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info"><i class="bi bi-eye"></i></a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger"><i class="bi bi-trash"></i></a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* --- VISÃO MOBILE: LISTA DE CARDS (Oculta no Desktop) --- *@
    <div class="d-md-none">
        @{
            int posicaoM = 1;
        }
        @foreach (var item in jogadoresOrdenados)
        {
            <div class="p-3 border-bottom border-secondary d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <div class="me-3 text-muted fw-bold" style="min-width: 25px;">@(posicaoM++)º</div>
                    <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://cdn-icons-png.flaticon.com/512/166/166344.png" : item.ImageUrl)"
                         class="rounded-circle border border-warning me-3" style="width: 50px; height: 50px; object-fit: cover;" />
                    <div>
                        <div class="text-white fw-bold mb-0">@item.Name</div>
                        <div class="badge @(item.Overall >= 85 ? "bg-warning text-dark" : "bg-success") py-1 px-2 mt-1">
                            @item.Overall.ToString("F0") OVR
                        </div>
                    </div>
                </div>
                <div class="dropdown">
                    <button class="btn btn-link text-white p-0" type="button" data-bs-toggle="dropdown">
                        <i class="bi bi-three-dots-vertical fs-4"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end shadow">
                        <li><a class="dropdown-item py-2" asp-action="Details" asp-route-id="@item.Id"><i class="bi bi-eye text-info me-2"></i> Ver Detalhes</a></li>
                        <li><a class="dropdown-item py-2" asp-action="Edit" asp-route-id="@item.Id"><i class="bi bi-pencil text-warning me-2"></i> Editar Atleta</a></li>
                        <li><hr class="dropdown-divider border-secondary"></li>
                        <li><a class="dropdown-item py-2 text-danger" asp-action="Delete" asp-route-id="@item.Id"><i class="bi bi-trash me-2"></i> Excluir</a></li>
                    </ul>
                </div>
            </div>
        }
    </div>
</div>

<style>
    /* Estilo para botões mobile */
    @@media (max-width: 576px) {
        .btn-md-grow {
            width: 100%;
        }
    }

    .bg-dark {
        background-color: #1a1d20 !important;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(255,255,255,0.03);
    }
</style>