@model IEnumerable<StarChampionship.Models.Player>

@{
    ViewData["Title"] = "Ranking de Jogadores";
    // Ordenação feita aqui para garantir que o melhor jogador apareça primeiro
    var jogadoresOrdenados = Model.OrderByDescending(p => p.Overall).ToList();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-warning"><i class="fas fa-trophy"></i> @ViewData["Title"]</h2>
    <a asp-action="Create" class="btn btn-warning btn-lg shadow">
        <i class="fas fa-plus-circle"></i> Novo Craque
    </a>
</div>

<div class="card bg-dark shadow border-secondary">
    <table class="table table-hover align-middle mb-0 text-white">
        <thead>
            <tr class="bg-primary text-white">
                <th style="width: 80px;" class="text-center border-0">#</th>
                <th style="width: 80px;" class="text-center border-0">Foto</th>
                <th class="border-0">Nome</th>
                <th class="text-center border-0">Overall</th>
                <th class="border-0">Principais Características</th>
                <th class="text-center border-0" style="min-width: 220px;">Gestão</th>
            </tr>
        </thead>
        <tbody>
            @{
                int posicao = 1;
            }
            @foreach (var item in jogadoresOrdenados)
            {
                var stats = new Dictionary<string, double>
                        {
                        { "Chute", item.Shoot },
                        { "Drible", item.Dribble },
                        { "Domínio", item.FirstTouch },
                        { "Controle", item.BallControl },
                        { "Defesa", item.Defense },
                        { "Passe", item.Pass },
                        { "Veloc.", item.Speed },
                        { "Força", item.Strength }
                        };

                var topStats = stats.OrderByDescending(s => s.Value).Take(3);

                <tr class="border-secondary">
                    <td class="text-center text-muted">
                        <strong>@(posicao++)º</strong>
                    </td>
                    <td class="text-center">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" class="rounded-circle border border-warning shadow-sm" style="width: 55px; height: 55px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="bg-secondary rounded-circle d-flex align-items-center justify-content-center text-white mx-auto shadow-sm" style="width: 55px; height: 55px;">
                                <i class="fas fa-user-ninja"></i>
                            </div>
                        }
                    </td>
                    <td>
                        <span class="h5 font-weight-bold mb-0">@item.Name</span>
                    </td>
                    <td class="text-center">
                        <span class="badge rounded-circle p-3 @(item.Overall >= 85 ? "bg-warning text-dark" : item.Overall >= 75 ? "bg-success" : "bg-info text-dark")"
                              style="width: 50px; height: 50px; display: inline-flex; align-items: center; justify-content: center; font-size: 1.2rem; border: 2px solid rgba(255,255,255,0.3);">
                            @item.Overall.ToString("F0")
                        </span>
                    </td>
                    <td>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var stat in topStats)
                            {
                                <span class="badge bg-primary text-white border border-light" style="font-size: 0.85rem; padding: 0.5rem 0.8rem;">
                                    @stat.Key: <strong class="text-warning">@stat.Value</strong>
                                </span>
                            }
                        </div>
                    </td>
                    <td class="text-center">
                        <div class="d-flex justify-content-center gap-2">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm px-3 shadow-sm text-dark fw-bold">
                                <i class="fas fa-edit"></i> Editar
                            </a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm px-3 shadow-sm text-dark fw-bold">
                                <i class="fas fa-search-plus"></i> Ver
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm px-3 shadow-sm fw-bold">
                                <i class="fas fa-trash-alt"></i> Excluir
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>