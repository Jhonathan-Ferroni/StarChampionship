@model IEnumerable<StarChampionship.Models.Player>

@{
    ViewData["Title"] = "Jogadores";
}

<div class="d-flex justify-content-between align-items-center">
    <h2>@ViewData["Title"]</h2>
    <p>
        <a asp-action="Create" class="btn btn-primary">Cadastrar Novo Jogador</a>
    </p>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr class="table-dark">
            <th style="width: 80px;">Foto</th>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>Posição</th>
            <th class="text-center">Overall</th>
            <th>Time</th>
            <th class="text-center">Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" class="rounded-circle" style="width: 50px; height: 50px; object-fit: cover;" />
                    }
                    else
                    {
                        <div class="bg-secondary rounded-circle d-flex align-items-center justify-content-center text-white" style="width: 50px; height: 50px; font-size: 10px;">
                            N/A
                        </div>
                    }
                </td>
                <td>
                    <strong>@Html.DisplayFor(modelItem => item.Name)</strong>
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Type)
                </td>
                <td class="text-center">
                    <span class="badge @(item.Overall >= 80 ? "bg-success" : "bg-primary")">
                        @item.Overall.ToString("F1")
                    </span>
                </td>
                <td class="text-center">
                    <div class="btn-group" role="group">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Editar</a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Detalhes</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Excluir</a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>