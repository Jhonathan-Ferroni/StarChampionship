@model StarChampionship.Models.Player

@{
    ViewData["Title"] = "Remover Jogador";
}

<div class="container mt-4 pb-5">
    @* Título Responsivo *@
    <h2 class="text-danger mb-4 text-center text-md-start">
        <i class="bi bi-exclamation-triangle-fill"></i> @ViewData["Title"]
    </h2>

    <div class="card border-danger bg-dark shadow-lg">
        @* Header com gradiente para maior destaque *@
        <div class="card-header bg-danger bg-gradient text-white py-3">
            <h5 class="mb-0 fw-bold text-center text-md-start">
                <i class="bi bi-shield-exclamation"></i> Atenção: Esta ação é permanente!
            </h5>
        </div>

        <div class="card-body text-white p-4">
            <div class="row align-items-center">
                @* Seção da Foto: Centralizada no Mobile, Lateral no Desktop *@
                <div class="col-md-3 text-center border-md-end border-secondary mb-4 mb-md-0">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="Foto de @Model.Name"
                             class="img-thumbnail shadow mb-2"
                             style="width: 140px; height: 140px; object-fit: cover; border-radius: 50%; border: 3px solid #dc3545;" />
                    }
                    else
                    {
                        <div class="bg-secondary text-white d-flex align-items-center justify-content-center mx-auto mb-2 shadow"
                             style="width: 140px; height: 140px; border-radius: 50%;">
                            <i class="bi bi-person-x-fill display-4"></i>
                        </div>
                    }
                    <div class="mt-2">
                        <h3 class="text-warning fw-bold mb-0">@Model.Overall.ToString("F0")</h3>
                        <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Overall</small>
                    </div>
                </div>

                @* Seção de Texto *@
                <div class="col-md-9 ps-md-4 text-center text-md-start">
                    <h3 class="display-6 fw-bold">@Model.Name</h3>
                    <p class="lead opacity-75">Você está prestes a excluir permanentemente este jogador do **StarChampionship**.</p>

                    <div class="alert alert-dark border-secondary mt-3 d-inline-block d-md-block text-start">
                        <i class="bi bi-info-circle-fill text-info"></i>
                        <small>
                            Todos os atributos técnicos e estatísticas de <strong>@Model.Name</strong> serão removidos definitivamente.
                        </small>
                    </div>
                </div>
            </div>
        </div>

        @* Footer com botões que ocupam largura total no Mobile *@
        <div class="card-footer bg-dark border-top border-secondary p-3">
            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                    <button type="submit" class="btn btn-danger btn-lg px-4 fw-bold shadow">
                        <i class="bi bi-trash3-fill"></i> Confirmar Exclusão
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">
                        Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    /* Ajuste para a borda lateral aparecer apenas no desktop */
    @@media (min-width: 768px) {
        .border-md-end {
            border-right: 1px solid rgba(255,255,255,0.1) !important;
        }
    }
</style>