@model StarChampionship.Models.Player

@{
    ViewData["Title"] = "Deletar Jogador";
}

<h2>@ViewData["Title"]</h2>

<h3 class="text-danger">Tem certeza que deseja remover este jogador?</h3>

<div>
    <h4>Ficha de Exclusão</h4>
    <hr />

    <div class="row">
        <div class="col-sm-2">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" class="img-thumbnail" style="width: 120px; height: 120px; object-fit: cover; border-radius: 10px;" />
            }
        </div>

        <div class="col-sm-10">
            <dl class="row">
                <dt class="col-sm-3">
                    @Html.DisplayNameFor(model => model.Name)
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.Name)
                </dd>

                <dt class="col-sm-3">
                    Posição
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.Type)
                </dd>

                <dt class="col-sm-3">
                    Overall
                </dt>
                <dd class="col-sm-9 text-primary font-weight-bold">
                    @Model.Overall.ToString("F1")
                </dd>

                <dt class="col-sm-3">
                    Time
                </dt>
            </dl>
        </div>
    </div>

    <form asp-action="Delete" class="mt-4">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Confirmar Exclusão</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar e Voltar</a>
    </form>
</div>