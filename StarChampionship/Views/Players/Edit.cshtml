@model StarChampionship.Models.Player
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Editar Jogador";
}

<h2>@ViewData["Title"]</h2>

<h4>Ficha do Jogador</h4>
<hr />

<div class="row">
    <div class="col-md-6">

        <form asp-action="Edit" method="post">

            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Type" class="control-label">Tipo/Posição</label>
                <input asp-for="Type" class="form-control" />
                <span asp-validation-for="Type" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="ImageUrl" class="control-label"></label>
                <input asp-for="ImageUrl" class="form-control" placeholder="URL da foto" />
                <span asp-validation-for="ImageUrl" class="text-danger"></span>
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="mt-2">
                        <small>Preview atual:</small><br />
                        <img src="@Model.ImageUrl" class="img-thumbnail" style="width: 80px; height: 80px; object-fit: cover; border-radius: 50%;" />
                    </div>
                }
            </div>

            <div class="row mt-3">
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="Shoot" class="control-label"></label>
                        <input asp-for="Shoot" type="number" class="form-control" />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="Defense" class="control-label"></label>
                        <input asp-for="Defense" type="number" class="form-control" />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="Pass" class="control-label"></label>
                        <input asp-for="Pass" type="number" class="form-control" />
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="Speed" class="control-label"></label>
                        <input asp-for="Speed" type="number" class="form-control" />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="Strength" class="control-label"></label>
                        <input asp-for="Strength" type="number" class="form-control" />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label class="control-label">Overall (Auto)</label>
                        <input class="form-control" disabled value="@Model.Overall.ToString("F1")" />
                    </div>
                </div>
            </div>


            <div class="form-group mt-4">
                <input type="submit" value="Salvar Alterações" class="btn btn-success" />
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}