@model StarChampionship.Models.Player
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Create New Player";
}

<div class="container">
    <h2>@ViewData["Title"]</h2>
    <h4>Ficha Técnica do Jogador</h4>
    <hr />

    <div class="row">
        <div class="col-md-8">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="Name" class="control-label">Nome do Craque</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="ImageUrl" class="control-label">Imagem (URL)</label>
                            <input asp-for="ImageUrl" class="form-control" placeholder="http://link-da-imagem.jpg" />
                            <span asp-validation-for="ImageUrl" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <hr />
                <h5>Atributos</h5>

                <div class="row">
                    <div class="col-md-3">
                        <div class="form-group">
                            <label asp-for="Shoot" class="control-label">Chute</label>
                            <input asp-for="Shoot" type="number" class="form-control" />
                            <span asp-validation-for="Shoot" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label asp-for="Dribble" class="control-label">Drible</label>
                            <input asp-for="Dribble" type="number" class="form-control" />
                            <span asp-validation-for="Dribble" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label asp-for="FirstTouch" class="control-label">Domínio</label>
                            <input asp-for="FirstTouch" type="number" class="form-control" />
                            <span asp-validation-for="FirstTouch" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label asp-for="BallControl" class="control-label">Controle</label>
                            <input asp-for="BallControl" type="number" class="form-control" />
                            <span asp-validation-for="BallControl" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row mt-2">
                    <div class="col-md-3">
                        <div class="form-group">
                            <label asp-for="Defense" class="control-label">Defesa</label>
                            <input asp-for="Defense" type="number" class="form-control" />
                            <span asp-validation-for="Defense" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label asp-for="Pass" class="control-label">Passe</label>
                            <input asp-for="Pass" type="number" class="form-control" />
                            <span asp-validation-for="Pass" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label asp-for="Speed" class="control-label">Velocidade</label>
                            <input asp-for="Speed" type="number" class="form-control" />
                            <span asp-validation-for="Speed" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label asp-for="Strength" class="control-label">Força</label>
                            <input asp-for="Strength" type="number" class="form-control" />
                            <span asp-validation-for="Strength" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="form-group mt-4">
                    <input type="submit" value="Salvar Jogador" class="btn btn-primary btn-lg" />
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg">Cancelar</a>
                </div>
            </form>
        </div>

        <div class="col-md-4">
            <div class="card bg-dark text-white p-3 mt-4">
                <h4>Preview</h4>
                <p>O <strong>Overall</strong> será calculado automaticamente após salvar.</p>
                <div class="text-center">
                    <i class="fas fa-user-shield fa-5x"></i>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}