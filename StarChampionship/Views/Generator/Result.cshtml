@using StarChampionship.Models
@{
    ViewData["Title"] = "Times Formados";
    var teamA = ViewBag.TeamA as List<Player>;
    var teamB = ViewBag.TeamB as List<Player>;
    var sumA = teamA?.Sum(p => p.Overall) ?? 0;
    var sumB = teamB?.Sum(p => p.Overall) ?? 0;
}

<div class="container mt-4">
    <div class="text-center mb-5">
        <h2><i class="bi bi-trophy"></i> Confronto Equilibrado</h2>
        <p class="text-muted">Os times foram divididos usando a lógica de Snake Draft para minimizar a diferença de nível.</p>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow border-primary">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">TIME A</h4>
                    <span class="badge bg-light text-primary">Total: @sumA.ToString("F1")</span>
                </div>
                <ul class="list-group list-group-flush">
                    @foreach (var p in teamA)
                    {
                        <li class="list-group-item d-flex align-items-center justify-content-between">
                            <div class="d-flex align-items-center">
                                <img src="@p.ImageUrl" class="rounded-circle me-3" style="width: 45px; height: 45px; object-fit: cover;" onerror="this.src='/img/default-player.png'">
                                <div>
                                    <h6 class="mb-0">@p.Name</h6>
                                    <small class="text-muted">@p.Type</small>
                                </div>
                            </div>
                            <span class="badge bg-secondary">@p.Overall.ToString("F1")</span>
                        </li>
                    }
                </ul>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow border-danger">
                <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">TIME B</h4>
                    <span class="badge bg-light text-danger">Total: @sumB.ToString("F1")</span>
                </div>
                <ul class="list-group list-group-flush">
                    @foreach (var p in teamB)
                    {
                        <li class="list-group-item d-flex align-items-center justify-content-between">
                            <div class="d-flex align-items-center">
                                <img src="@p.ImageUrl" class="rounded-circle me-3" style="width: 45px; height: 45px; object-fit: cover;" onerror="this.src='/img/default-player.png'">
                                <div>
                                    <h6 class="mb-0">@p.Name</h6>
                                    <small class="text-muted">@p.Type</small>
                                </div>
                            </div>
                            <span class="badge bg-secondary">@p.Overall.ToString("F1")</span>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>

    <div class="text-center mt-5">
        <div class="alert @(Math.Abs(sumA - sumB) < 5 ? "alert-success" : "alert-warning") d-inline-block">
            <strong>Diferença de Força:</strong> @(Math.Abs(sumA - sumB).ToString("F1")) pontos de Overall.
        </div>

        <br />

        <form asp-action="Generate" method="post" class="d-inline">
            @foreach (var id in (int[])ViewBag.SelectedIds)
            {
                <input type="hidden" name="selectedIds" value="@id" />
            }
            <button type="submit" class="btn btn-success mt-3">
                <i class="bi bi-arrow-repeat"></i> Sortear Novamente
            </button>
        </form>

        <a asp-action="Index" class="btn btn-outline-dark mt-3 ms-2">
            <i class="bi bi-arrow-left"></i> Refazer Seleção
        </a>
    </div>
</div>