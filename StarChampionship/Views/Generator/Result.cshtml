@using StarChampionship.Models
@{
    ViewData["Title"] = "Times Formados";
    var teamA = ViewBag.TeamA as List<Player>;
    var teamB = ViewBag.TeamB as List<Player>;
    var sumA = teamA?.Sum(p => p.Overall) ?? 0;
    var sumB = teamB?.Sum(p => p.Overall) ?? 0;
    var difference = (double)ViewBag.Difference;
    var margin = (double)ViewBag.Margin;
}

<div class="container mt-4">
    @* Cabeçalho de Status *@
    <div class="text-center mb-4">
        <h2 class="text-white"><i class="bi bi-shield-shaded text-info"></i> Confronto Equilibrado</h2>
        <div class="d-flex justify-content-center mt-3">
            <div class="alert @(difference <= margin ? "alert-success" : "alert-warning") border-0 shadow-sm px-4 py-2">
                <span class="fw-bold">
                    @(difference <= margin ? "✅ EQUILÍBRIO ALCANÇADO" : "⚠️ DIFERENÇA ALTA")
                </span>
                <span class="mx-2 text-muted">|</span>
                <small>Diferença: <strong>@difference.ToString("F1")</strong> pts</small>
            </div>
        </div>
    </div>

    @* Área dos Times *@
    <div class="row g-4">
        @* TIME A *@
        <div class="col-lg-6">
            <div class="card bg-dark border-primary shadow">
                <div class="card-header bg-primary bg-gradient text-white d-flex justify-content-between align-items-center py-2">
                    <h5 class="mb-0 fw-bold">TIME A</h5>
                    <span class="badge bg-white text-primary fw-bold">Total: @sumA.ToString("F1")</span>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        @foreach (var p in teamA)
                        {
                            <li class="list-group-item bg-dark border-secondary d-flex align-items-center justify-content-between py-2">
                                <div class="d-flex align-items-center">
                                    <img src="@(string.IsNullOrEmpty(p.ImageUrl) ? "https://cdn-icons-png.flaticon.com/512/166/166344.png" : p.ImageUrl)"
                                         class="rounded-circle border border-secondary me-3" style="width: 40px; height: 40px; object-fit: cover;">
                                    <div>
                                        <h6 class="text-white mb-0 small">@p.Name</h6>
                                        <small class="text-info" style="font-size: 0.65rem;">Top Atributos</small>
                                    </div>
                                </div>
                                <span class="badge bg-secondary opacity-75">@p.Overall.ToString("F1")</span>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>

        @* TIME B *@
        <div class="col-lg-6">
            <div class="card bg-dark border-danger shadow">
                <div class="card-header bg-danger bg-gradient text-white d-flex justify-content-between align-items-center py-2">
                    <h5 class="mb-0 fw-bold">TIME B</h5>
                    <span class="badge bg-white text-danger fw-bold">Total: @sumB.ToString("F1")</span>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        @foreach (var p in teamB)
                        {
                            <li class="list-group-item bg-dark border-secondary d-flex align-items-center justify-content-between py-2">
                                <div class="d-flex align-items-center">
                                    <img src="@(string.IsNullOrEmpty(p.ImageUrl) ? "https://cdn-icons-png.flaticon.com/512/166/166344.png" : p.ImageUrl)"
                                         class="rounded-circle border border-secondary me-3" style="width: 40px; height: 40px; object-fit: cover;">
                                    <div>
                                        <h6 class="text-white mb-0 small">@p.Name</h6>
                                        <small class="text-info" style="font-size: 0.65rem;">Top Atributos</small>
                                    </div>
                                </div>
                                <span class="badge bg-secondary opacity-75">@p.Overall.ToString("F1")</span>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>

    @* Controles Inferiores *@
    <div class="mt-5 text-center">
        <div class="row justify-content-center g-3">
            <div class="col-12 col-md-6">
                <div class="card bg-dark border-secondary p-3 shadow-sm">
                    <form asp-action="Generate" method="post">
                        @foreach (var id in (int[])ViewBag.SelectedIds)
                        {
                            <input type="hidden" name="selectedIds" value="@id" />
                        }

                        <label class="form-label text-white small mb-2">Refinar Margem de Erro:</label>
                        <div class="input-group">
                            <input type="number" name="margin" step="0.5" value="@margin" class="form-control bg-dark border-secondary text-white text-center fw-bold" />
                            <button type="submit" class="btn btn-outline-success">
                                <i class="bi bi-arrow-repeat"></i> Re-sortear
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="mt-4 pb-5">
            <a asp-action="Index" class="btn btn-outline-light px-4">
                <i class="bi bi-arrow-left"></i> Nova Seleção
            </a>
            <button class="btn btn-info px-4 ms-md-2 mt-2 mt-md-0 shadow text-dark fw-bold" onclick="window.print()">
                <i class="bi bi-share"></i> Print dos Times
                </a>
        </div>
    </div>
</div>

<style>
    /* Ajustes finos para Mobile */
    @@media (max-width: 768px) {
        .card-header h5 {
            font-size: 1rem;
        }

        .list-group-item h6 {
            font-size: 0.85rem;
        }

        .alert {
            width: 100%;
            font-size: 0.85rem;
        }
    }

    /* Cores de fundo fixas para dark mode */
    .bg-dark {
        background-color: #1a1d20 !important;
    }

    .list-group-item {
        border-color: rgba(255,255,255,0.1) !important;
    }
</style>