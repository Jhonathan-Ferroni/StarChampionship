@model IEnumerable<StarChampionship.Models.Player>

@{
    ViewData["Title"] = "Gerador de Times";
}

<div class="container mt-4">
    @* Cabeçalho Responsivo *@
    <div class="row align-items-center border-bottom border-secondary pb-3 mb-4">
        <div class="col-8 col-md-8">
            <h2 class="text-white mb-0"><i class="bi bi-cpu text-info"></i> <span class="d-none d-sm-inline">@ViewData["Title"]</span><span class="d-inline d-sm-none">Gerador</span></h2>
        </div>
        <div class="col-4 col-md-4 text-end">
            <button type="submit" form="generator-form" class="btn btn-success shadow-sm btn-sm btn-md-grow">
                <i class="bi bi-shuffle"></i> <span class="d-none d-md-inline">Gerar Equipes</span><span class="d-inline d-md-none">Gerar</span>
            </button>
        </div>
    </div>

    <form asp-action="Generate" method="post" id="generator-form">
        @* Card de Rigor - Ajustado para Mobile *@
        <div class="card bg-dark mb-4 shadow-sm border-secondary">
            <div class="card-body py-3">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <label for="marginRange" class="form-label fw-bold text-white mb-1 small">
                            <i class="bi bi-sliders text-info"></i> Rigor do Equilíbrio:
                            <span id="marginValue" class="badge bg-success ms-2">2.0</span> <span class="text-success small">pts</span>
                        </label>
                        <input type="range" name="margin" class="form-range" min="0" max="50" step="0.5" value="2.0" id="marginRange">
                        <div class="d-flex justify-content-between">
                            <small class="text-muted" style="font-size: 0.7rem;">0.0 (Pro)</small>
                            <small class="text-muted" style="font-size: 0.7rem;">50.0 (Várzea)</small>
                        </div>
                    </div>
                    <div class="col-md-6 text-end d-none d-md-block">
                        <p class="mb-0 text-info small italic" style="opacity: 0.8;">O algoritmo prioriza a média de overall dentro da margem escolhida.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-secondary">
            <div class="card-header bg-primary py-2 d-flex justify-content-between align-items-center">
                <h6 class="mb-0 text-white">Atletas Disponíveis</h6>
                <span id="selected-count" class="badge bg-info text-dark fw-bold">0 selecionados</span>
            </div>

            <div class="card-body p-0 bg-dark">

                @* --- VISÃO DESKTOP: TABELA (Aparece em telas Médias/Grandes) --- *@
                <div class="table-responsive d-none d-md-block">
                    <table class="table table-dark table-hover align-middle mb-0" style="font-size: 0.9rem;">
                        <thead>
                            <tr class="table-active">
                                <th style="width: 50px;" class="text-center">
                                    <input type="checkbox" id="selectAllDesktop" class="form-check-input border-light select-all-btn" style="cursor: pointer;" />
                                </th>
                                <th style="width: 60px;">Foto</th>
                                <th>Nome</th>
                                <th>Top Características</th>
                                <th class="text-center" style="width: 100px;">Overall</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center">
                                        <input type="checkbox" name="selectedIds" value="@item.Id" class="form-check-input player-checkbox border-light" />
                                    </td>
                                    <td>
                                        <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://cdn-icons-png.flaticon.com/512/166/166344.png" : item.ImageUrl)"
                                             class="rounded-circle border border-secondary" style="width: 35px; height: 35px; object-fit: cover;" />
                                    </td>
                                    <td class="text-white fw-bold">@item.Name</td>
                                    <td>
                                        <div class="d-flex gap-1">
                                            <span class="badge border border-info text-info small" style="font-size: 0.7rem;">Velocidade</span>
                                            <span class="badge border border-info text-info small" style="font-size: 0.7rem;">Passe</span>
                                            <span class="badge border border-info text-info small" style="font-size: 0.7rem;">Drible</span>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @(item.Overall >= 80 ? "bg-success" : "bg-info") text-dark fw-bold" style="min-width: 45px;">
                                            @item.Overall.ToString("F1")
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @* --- VISÃO MOBILE: CARDS (Aparece apenas em telas Pequenas) --- *@
                <div class="d-md-none p-2">
                    <div class="d-flex justify-content-between align-items-center mb-3 px-2">
                        <small class="text-muted uppercase fw-bold" style="font-size: 0.65rem;">Selecionar Todos</small>
                        <input type="checkbox" id="selectAllMobile" class="form-check-input border-light select-all-btn" />
                    </div>
                    @foreach (var item in Model)
                    {
                        <div class="player-card-mobile bg-secondary bg-opacity-10 border border-secondary rounded p-2 mb-2 shadow-sm" style="cursor: pointer;">
                            <div class="row align-items-center g-0">
                                <div class="col-2 text-center">
                                    <input type="checkbox" name="selectedIds" value="@item.Id" class="form-check-input player-checkbox border-light">
                                </div>
                                <div class="col-2 text-center">
                                    <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://cdn-icons-png.flaticon.com/512/166/166344.png" : item.ImageUrl)"
                                         class="rounded-circle" style="width: 35px; height: 35px; object-fit: cover;" />
                                </div>
                                <div class="col-5 ps-2">
                                    <div class="text-white fw-bold small">@item.Name</div>
                                    <div class="text-info" style="font-size: 0.65rem; opacity: 0.8;">Velocidade, Passe, Drible</div>
                                </div>
                                <div class="col-3 text-end ps-1">
                                    <span class="badge @(item.Overall >= 80 ? "bg-success" : "bg-info") text-dark fw-bold" style="font-size: 0.75rem;">
                                        @item.Overall.ToString("F1")
                                    </span>
                                </div>
                            </div>
                        </div>
                    }
                </div>

            </div>
            <div class="card-footer bg-dark border-top border-secondary py-2">
                <small class="text-muted" style="font-size: 0.75rem;"><i class="bi bi-info-circle text-info"></i> Selecione os atletas para o sorteio.</small>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        // Sincronização e Lógica de Seleção
        const marginRange = document.getElementById('marginRange');
        const marginValue = document.getElementById('marginValue');

        marginRange.addEventListener('input', function() {
            marginValue.innerText = parseFloat(this.value).toFixed(1);
            if (this.value <= 2.0) marginValue.className = "badge bg-success ms-2";
            else if (this.value <= 5.0) marginValue.className = "badge bg-warning text-dark ms-2";
            else marginValue.className = "badge bg-danger ms-2";
        });

        const selectAllBtns = document.querySelectorAll('.select-all-btn');
        const checkboxes = document.querySelectorAll('.player-checkbox');
        const countBadge = document.getElementById('selected-count');

        function updateSelectedCount() {
            const selected = document.querySelectorAll('.player-checkbox:checked').length / (window.innerWidth >= 768 ? 1 : 1);
            // Como temos checkboxes duplicados em views diferentes, o name="selectedIds" garante que o POST funcione,
            // mas o JS precisa contar apenas os únicos se você renderizar os dois ao mesmo tempo.
            // Por segurança, vamos contar os IDs únicos selecionados:
            const uniqueSelected = new Set([...document.querySelectorAll('.player-checkbox:checked')].map(cb => cb.value)).size;

            countBadge.innerText = `${uniqueSelected} selecionados`;
            countBadge.className = uniqueSelected > 0 ? 'badge bg-warning text-dark fw-bold' : 'badge bg-info text-dark fw-bold';
        }

        selectAllBtns.forEach(btn => {
            btn.addEventListener('change', function() {
                checkboxes.forEach(cb => cb.checked = this.checked);
                selectAllBtns.forEach(b => b.checked = this.checked);
                updateSelectedCount();
            });
        });

        checkboxes.forEach(cb => {
            cb.addEventListener('change', function() {
                // Sincroniza checkbox mobile/desktop do mesmo jogador se ambos existirem
                const samePlayers = document.querySelectorAll(`.player-checkbox[value="${this.value}"]`);
                samePlayers.forEach(p => p.checked = this.checked);

                updateSelectedCount();
                const allChecked = document.querySelectorAll('.player-checkbox:checked').length > 0;
            });
        });

        // Clique no Card Mobile também seleciona
        document.querySelectorAll('.player-card-mobile').forEach(card => {
            card.addEventListener('click', function(e) {
                if (e.target.type !== 'checkbox') {
                    const cb = this.querySelector('.player-checkbox');
                    cb.checked = !cb.checked;
                    cb.dispatchEvent(new Event('change'));
                }
            });
        });
    </script>
}