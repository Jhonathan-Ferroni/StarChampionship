@model IEnumerable<StarChampionship.Models.Player>

@{
    ViewData["Title"] = "Gerador de Times";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12 border-bottom pb-2 mb-4 d-flex justify-content-between align-items-center">
            <h2><i class="bi bi-cpu"></i> @ViewData["Title"]</h2>
            <button type="submit" form="generator-form" class="btn btn-success btn-lg shadow-sm">
                <i class="bi bi-shuffle"></i> Gerar Times Equilibrados
            </button>
        </div>
    </div>

    <form asp-action="Generate" method="post" id="generator-form">
        <div class="row">
            <div class="col-md-12">
                <div class="card shadow-sm">
                    <div class="card-header bg-dark text-white">
                        <h5 class="mb-0">Selecione os Jogadores para a Partida</h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 50px;">Escalar</th>
                                        <th>Foto</th>
                                        <th>Nome</th>
                                        <th>Posição</th>
                                        <th class="text-center">Overall</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="text-center">
                                                <input type="checkbox" name="selectedIds" value="@item.Id" class="form-check-input shadow-none" style="transform: scale(1.5);" />
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                                {
                                                    <img src="@item.ImageUrl" class="rounded-circle" style="width: 40px; height: 40px; object-fit: cover;" />
                                                }
                                                else
                                                {
                                                    <div class="bg-secondary rounded-circle d-flex align-items-center justify-content-center text-white" style="width: 40px; height: 40px; font-size: 10px;">N/A</div>
                                                }
                                            </td>
                                            <td><strong>@item.Name</strong></td>
                                            <td><span class="badge bg-light text-dark border">@item.Type</span></td>
                                            <td class="text-center">
                                                <span class="badge @(item.Overall >= 80 ? "bg-success" : "bg-primary")">
                                                    @item.Overall.ToString("F1")
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="card-footer text-muted">
                        Dica: Selecione um número par de jogadores para um melhor balanceamento.
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        // Opcional: Script para limitar a seleção em 10 ou 12 jogadores, por exemplo.
        document.querySelectorAll('input[type="checkbox"]').forEach(checkbox => {
            checkbox.addEventListener('change', function() {
                const checkedCount = document.querySelectorAll('input[name="selectedIds"]:checked').length;
                console.log("Jogadores selecionados: " + checkedCount);
            });
        });
    </script>
}