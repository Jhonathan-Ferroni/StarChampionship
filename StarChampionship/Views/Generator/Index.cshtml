@model IEnumerable<StarChampionship.Models.Player>

@{
    ViewData["Title"] = "Gerador de Times";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12 border-bottom border-secondary pb-2 mb-4 d-flex justify-content-between align-items-center">
            <h2 class="text-white"><i class="bi bi-cpu text-info"></i> @ViewData["Title"]</h2>
            <button type="submit" form="generator-form" class="btn btn-success btn-lg shadow">
                <i class="bi bi-shuffle"></i> Gerar Times Equilibrados
            </button>
        </div>
    </div>

    <form asp-action="Generate" method="post" id="generator-form">

        <div class="card bg-dark mb-4 shadow border-secondary">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-5">
                        <label for="marginRange" class="form-label fw-bold text-white mb-2">
                            <i class="bi bi-sliders text-info"></i> Margem de Tolerância:
                            <span id="marginValue" class="badge bg-success ms-2">2.0</span> <span class="text-success small">pts</span>
                        </label>

                        <input type="range" name="margin" class="form-range" min="0" max="50" step="0.5" value="2.0" id="marginRange">

                        <div class="d-flex justify-content-between">
                            <small class="text-muted">0.0 (Perfeito)</small>
                            <small class="text-muted">25.0 (Médio)</small>
                            <small class="text-muted">50.0 (Várzea)</small>
                        </div>
                    </div>
                    <div class="col-md-7 text-end d-none d-md-block">
                        <p class="mb-0 text-info italic">Arraste para definir o rigor do equilíbrio. <br> Menores valores garantem times mais parelhos.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-12">
                <div class="card shadow border-secondary">
                    <div class="card-header bg-primary d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 text-white">Lista de Atletas</h5>
                        <span id="selected-count" class="badge bg-info text-dark fw-bold">0 selecionados</span>
                    </div>
                    <div class="card-body p-0 bg-dark">
                        <div class="table-responsive">
                            <table class="table table-dark table-hover align-middle mb-0">
                                <thead>
                                    <tr class="table-active">
                                        <th style="width: 80px;" class="text-center">
                                            <div class="form-check d-flex justify-content-center">
                                                <input type="checkbox" id="selectAll" class="form-check-input border-light" style="transform: scale(1.3); cursor: pointer;" />
                                            </div>
                                        </th>
                                        <th style="width: 80px;">Foto</th>
                                        <th>Nome</th>
                                        <th>Posição</th>
                                        <th class="text-center">Overall</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="text-center">
                                                <input type="checkbox" name="selectedIds" value="@item.Id" class="form-check-input player-checkbox border-light" style="transform: scale(1.3);" />
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                                {
                                                    <img src="@item.ImageUrl" class="rounded-circle border border-secondary" style="width: 40px; height: 40px; object-fit: cover;" onerror="this.src='https://cdn-icons-png.flaticon.com/512/166/166344.png'" />
                                                }
                                                else
                                                {
                                                    <div class="bg-secondary rounded-circle d-flex align-items-center justify-content-center text-white" style="width: 40px; height: 40px; font-size: 10px;">N/A</div>
                                                }
                                            </td>
                                            <td class="text-white fw-bold">@item.Name</td>
                                            <td><span class="badge border border-info text-info">@item.Type</span></td>
                                            <td class="text-center">
                                                <span class="badge @(item.Overall >= 80 ? "bg-success" : "bg-info") text-dark fw-bold">
                                                    @item.Overall.ToString("F1")
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="card-footer bg-dark border-top border-secondary text-muted">
                        <small><i class="bi bi-info-circle text-info"></i> O algoritmo realizará até 1000 tentativas para encontrar o melhor equilíbrio.</small>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        // Seletores do Slider
        const marginRange = document.getElementById('marginRange');
        const marginValue = document.getElementById('marginValue');

        // Atualiza o valor do texto do slider
        marginRange.addEventListener('input', function() {
            marginValue.innerText = parseFloat(this.value).toFixed(1);

            // Troca a cor do badge conforme o rigor
            if (this.value <= 2.0) {
                marginValue.className = "badge bg-success ms-2";
            } else if (this.value <= 5.0) {
                marginValue.className = "badge bg-warning text-dark ms-2";
            } else {
                marginValue.className = "badge bg-danger ms-2";
            }
        });

        // Seletores de Checkbox
        const selectAllBtn = document.getElementById('selectAll');
        const checkboxes = document.querySelectorAll('.player-checkbox');
        const countBadge = document.getElementById('selected-count');

        function updateSelectedCount() {
            const selected = document.querySelectorAll('.player-checkbox:checked').length;
            countBadge.innerText = `${selected} selecionados`;
            if(selected > 0) {
                countBadge.classList.replace('bg-info', 'bg-warning');
            } else {
                countBadge.classList.replace('bg-warning', 'bg-info');
            }
        }

        selectAllBtn.addEventListener('change', function() {
            checkboxes.forEach(cb => {
                cb.checked = this.checked;
            });
            updateSelectedCount();
        });

        checkboxes.forEach(cb => {
            cb.addEventListener('change', function() {
                updateSelectedCount();
                if (!this.checked) {
                    selectAllBtn.checked = false;
                } else if (document.querySelectorAll('.player-checkbox:checked').length === checkboxes.length) {
                    selectAllBtn.checked = true;
                }
            });
        });
    </script>
}