# ============================================
# 🔐 ENVIRONMENT VARIABLES TEMPLATE
# ============================================
# IMPORTANTE: Copie este arquivo para .env na raiz do projeto
# NUNCA faça commit de arquivo .env com valores reais!
# Este arquivo serve como documentação e exemplo para a equipe

# ============================================
# JWT Configuration (Autenticação)
# ============================================

# Chave secreta para assinar tokens JWT
# ⚠️  SEGURANÇA: Deve ter MÍNIMO 32 caracteres para HS256
# Para gerar uma chave segura, use:
#   PowerShell: [Convert]::ToBase64String([System.Text.Encoding]::UTF8.GetBytes((New-Guid).ToString() + (New-Guid).ToString()))
#   Linux: head -c 32 /dev/urandom | base64
JWT_SECRET_KEY=SuaChaveSecretaSuperSeguraComPeloMenos32Caracteres!@#$%^&*()

# Emissor do token (deve corresponder ao TokenValidationParameters em Program.cs)
JWT_ISSUER=StarChampionshipApi

# Audiência esperada do token (deve corresponder ao TokenValidationParameters em Program.cs)
JWT_AUDIENCE=StarChampionshipUsers

# Tempo de expiração do token em minutos
JWT_EXPIRATION_MINUTES=60

# ============================================
# Admin Configuration (Autorização)
# ============================================

# Senha do Admin (login via POST /api/auth/login)
# ⚠️  SEGURANÇA: Senhas fortes devem ter:
#     - Mínimo 12 caracteres
#     - Letras maiúsculas e minúsculas
#     - Números
#     - Caracteres especiais
ADMIN_PASSWORD=SenhaDeAdminSuperSegura123!@#

# ============================================
# Environment Configuration
# ============================================

# Ambiente de execução (Development, Staging, Production)
ASPNETCORE_ENVIRONMENT=Development

# ============================================
# INSTRUÇÕES DE USO
# ============================================
#
# 1. LOCAL DEVELOPMENT (Windows PowerShell):
#    $env:JWT_SECRET_KEY="sua-chave-aqui"
#    $env:ADMIN_PASSWORD="sua-senha-aqui"
#    dotnet run --launch-profile StarChampionshipSecure
#
# 2. LOCAL DEVELOPMENT (Linux/Mac bash):
#    export JWT_SECRET_KEY="sua-chave-aqui"
#    export ADMIN_PASSWORD="sua-senha-aqui"
#    dotnet run --launch-profile StarChampionshipSecure
#
# 3. LOCAL DEVELOPMENT (Com arquivo .env):
#    cp .env.example .env
#    # Editar .env com valores reais (NÃO commitar!)
#    dotnet run --launch-profile StarChampionshipSecure
#
# 4. PRODUCTION (Azure App Service):
#    Configure as variáveis na aba "Environment variables" ou via Azure Portal
#
# 5. CI/CD (GitHub Actions):
#    Configure os secrets em Settings > Secrets and variables > Actions
#    Então use: env: { JWT_SECRET_KEY: ${{ secrets.JWT_SECRET_KEY }} }
