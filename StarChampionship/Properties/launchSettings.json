{
  "$schema": "http://json.schemastore.org/launchsettings.json",
  "profiles": {
    "StarChampionship": {
      "commandName": "Project",
      "launchBrowser": true,
      "launchUrl": "https://localhost:64913",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:64913;http://localhost:64914"
      },
      "applicationUrl": "https://localhost:64913;http://localhost:64914",
      "dotnetRunMessages": true
    },
    "StarChampionshipSecure": {
      "commandName": "Project",
      "launchBrowser": true,
      "launchUrl": "https://localhost:64913",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:64913;http://localhost:64914",
        "JWT_SECRET_KEY": "${JWT_SECRET_KEY}",
        "ADMIN_PASSWORD": "${ADMIN_PASSWORD}",
        "JWT_ISSUER": "StarChampionshipApi",
        "JWT_AUDIENCE": "StarChampionshipUsers",
        "JWT_EXPIRATION_MINUTES": "60"
      },
      "applicationUrl": "https://localhost:64913;http://localhost:64914",
      "dotnetRunMessages": true
    }
  }
}